# Mathingo — example environment variables.
# Copy this file to .env and fill in real values. Never commit .env.

# ---- Compose stack selector ----
# Tells `docker compose` which override to merge with the base file.
# On a dev machine:
#   COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
# On the production VPS:
#   COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
COMPOSE_FILE=

# ---- General ----
# Application environment: development | production
ENVIRONMENT=development

# ---- Production deployment (nginx + Let's Encrypt) ----
# Apex domain — used by nginx server_name and certbot.
# www.${DOMAIN} is included automatically.
DOMAIN=mathingo.cz
# Let's Encrypt notification email (expiry warnings, etc.).
LE_EMAIL=

# ---- Frontend (Next.js) ----
# Public URL of the deployed frontend (used in emails, OG tags, etc.)
# Local example: http://localhost:3000
NEXT_PUBLIC_APP_URL=
# Internal URL of the backend reached from the frontend container.
# Inside docker-compose this is the service name: http://backend:8000
BACKEND_INTERNAL_URL=
# Base URL for client-side API calls from the browser.
# Production: leave empty (the helper defaults to /api → reverse proxy).
# Local dev:  http://localhost:8000 (the host-published backend port).
NEXT_PUBLIC_API_URL=

# ---- Backend (FastAPI) ----
# Secret used to sign session cookies / tokens.
# Generate with: openssl rand -hex 32
SECRET_KEY=
# Comma-separated list of origins allowed by CORS.
# Local example: http://localhost:3000
BACKEND_CORS_ORIGINS=

# Resend API key for transactional email (magic-link delivery).
# Get from https://resend.com → API Keys.
RESEND_API_KEY=

# JWT signing secret for session cookies — keep different from SECRET_KEY.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Public-facing application URL — used as the base of magic link URLs in emails.
# Local example: http://localhost:3000
APP_URL=

# Anthropic Claude API — powers the in-lesson AI explanation chat.
# Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=
# Model id; default claude-sonnet-4-6. Override to swap models.
ANTHROPIC_MODEL=
# Per-user daily and per-session message caps for the AI chat.
CHAT_DAILY_MESSAGE_LIMIT=
CHAT_SESSION_MESSAGE_LIMIT=

# ---- Web Push (VAPID) ----
# Identifies our server to push services (FCM, Mozilla Autopush, Apple).
# Generate the keypair once and persist it — rotating invalidates every
# subscription stored in push_subscriptions.
#   docker compose exec backend python scripts/generate_vapid_keys.py
# Then paste the printed values here. VAPID_PUBLIC_KEY is base64url; the
# frontend fetches it via /api/push/vapid-public-key for pushManager.subscribe.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# mailto: address shown to push services if they need to contact us about
# abuse / delivery problems. RFC 8292 requires a contact URI.
VAPID_SUBJECT=mailto:filipcupl20@gmail.com

# ---- PostgreSQL ----
# Used by docker-compose to provision the postgres container.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Async DSN consumed by the backend (asyncpg driver).
# Inside docker-compose this points at the postgres service name:
#   postgresql+asyncpg://<user>:<password>@postgres:5432/<db>
DATABASE_URL=

# ---- SMTP (magic-link emails) ----
# Not yet wired into the application — placeholders for an upcoming
# auth feature. Leave blank locally until the magic-link flow lands.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
